#!/bin/bash

# НАСТРОЙКА ТОЧНОГО ВРЕМЕНИ (Формат строго ЧЧ:ММ)
DAY_TIME="07:30"   # Во сколько утром экран станет обычным
NIGHT_TIME="22:30" # Во сколько вечером экран станет теплым

# Переводим настройки времени в минуты от начала суток
DAY_START=$(( 10#${DAY_TIME%%:*} * 60 + 10#${DAY_TIME##*:} ))
NIGHT_START=$(( 10#${NIGHT_TIME%%:*} * 60 + 10#${NIGHT_TIME##*:} ))

while true; do
    # Получаем текущие часы и минуты
    H=$(date +%H)
    M=$(date +%M)
    
    # Переводим текущее системное время в минуты от начала суток
    CURRENT_MINUTES=$(( 10#$H * 60 + 10#$M ))
    
    # Проверяем, попадает ли текущее время в дневной интервал
    if [ "$CURRENT_MINUTES" -ge "$DAY_START" ] && [ "$CURRENT_MINUTES" -lt "$NIGHT_START" ]; then
        xsct 6500   # Дневной режим
    else
        xsct 3600   # Ночной режим
    fi
    
    # Проверяем точное время раз в 60 секунд
    sleep 60
done

